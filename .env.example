# AgentOS environment template.
# Copy to .env and fill in values. .env is gitignored.

# --- Server ---
AGENTOS_HOST=127.0.0.1
AGENTOS_PORT=8000
AGENTOS_LOG_LEVEL=info

# --- LLM providers (only set what your agents' manifests reference) ---
TOGETHER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Storage (only set what your cells need) ---
DATABASE_URL=                 # e.g. postgresql://localhost:5432/agentos
REDIS_URL=                    # e.g. redis://localhost:6379/0
CHROMA_PATH=./data/chroma     # local Chroma persistence path

# --- Vector / retrieval (optional) ---
PINECONE_API_KEY=
PINECONE_ENV=
QDRANT_URL=
QDRANT_API_KEY=
